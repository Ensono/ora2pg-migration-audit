# Oracle to PostgreSQL Migration Audit - Environment Configuration
#
# IMPORTANT: All variables marked as REQUIRED must be set for the validator to run.
# Missing required variables will result in a clear error message at startup.
#
# Required variables for Comparison Mode (EXTRACT_SINGLE_DB=false):
#   - ORACLE_HOST, ORACLE_PORT, ORACLE_SERVICE, ORACLE_USER, ORACLE_PASSWORD, ORACLE_SCHEMA
#   - POSTGRES_HOST, POSTGRES_PORT, POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_SCHEMA
#   - At least one of: TABLES_TO_COMPARE or VIEWS_TO_COMPARE
#
# Required variables for Single Database Mode (EXTRACT_SINGLE_DB=true):
#   - Configuration for the target database (Oracle OR PostgreSQL)
#   - TARGET_DATABASE must be set to ORACLE or POSTGRESQL

# ============================================================================
# ORACLE DATABASE CONFIGURATION (REQUIRED for comparison mode)
# ============================================================================
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
ORACLE_USER=system
# Note: If password contains special characters like $, ", `, wrap it in single quotes:
#   ORACLE_PASSWORD='P@ssw0rd!with$pecial'
ORACLE_PASSWORD=your_oracle_password

# ============================================================================
# POSTGRESQL DATABASE CONFIGURATION (REQUIRED for comparison mode)
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
# Note: If password contains special characters like $, ", `, wrap it in single quotes:
#   POSTGRES_PASSWORD='P@ssw0rd!with$pecial'
POSTGRES_PASSWORD=your_postgres_password

# ============================================================================
# COMPARISON CONFIGURATION
# ============================================================================

# Extraction Mode:
#   false = Compare two databases (Oracle vs PostgreSQL)
#   true  = Extract from one database only
EXTRACT_SINGLE_DB=false

# Target Database (only used when EXTRACT_SINGLE_DB=true):
#   ORACLE or POSTGRESQL
TARGET_DATABASE=ORACLE

# Tables to Compare (REQUIRED: At least one of TABLES_TO_COMPARE or VIEWS_TO_COMPARE must be set):
#   Option 1: ALL - Auto-discover all common tables
#   Option 2: Comma-separated list - myschema.table1,myschema.table2,myschema.table3
#   Option 3: Explicit mapping - ORACLE_SCHEMA.TABLE1=postgres_schema.table1,ORACLE_SCHEMA.TABLE2=postgres_schema.table2
#   Option 4: Leave empty to compare views only (if VIEWS_TO_COMPARE is set)
TABLES_TO_COMPARE=ALL

# Schemas for Auto-Discovery (required when TABLES_TO_COMPARE=ALL or VIEWS_TO_COMPARE=ALL):
#   Replace with your actual schema names
#   Oracle schemas are typically UPPERCASE
#   PostgreSQL schemas are typically lowercase
#   REQUIRED for comparison mode
ORACLE_SCHEMA=YOUR_ORACLE_SCHEMA
POSTGRES_SCHEMA=your_postgres_schema

# Views to Compare (optional):
#   Option 1: ALL - Auto-discover all common views
#   Option 2: Comma-separated list - myschema.view1,myschema.view2
#   Option 3: Leave empty to skip view comparison
VIEWS_TO_COMPARE=

# View Exclusion Patterns (comma-separated substring matches):
#   Views containing any of these values will be excluded from validation
#   Example: temp_,test_,debug_,backup_
VIEW_EXCLUSION_PATTERNS=

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Row Limiting (0 = unlimited, >0 = limit rows per table):
MAX_ROWS_PER_TABLE=0

# Batch Processing:
BATCH_SIZE=5000
FETCH_SIZE=1000

# Connection Pooling:
CONNECTION_POOL_SIZE=10

# Database Command Timeout (in seconds):
#   Default: 300 (5 minutes)
#   Increase for very large tables or slow networks
COMMAND_TIMEOUT_SECONDS=300

# ============================================================================
# PERFORMANCE VALIDATOR SETTINGS (Ora2PgPerformanceValidator)
# ============================================================================

# Number of warmup runs before measurement (default: 1):
#   Warmup runs prime database caches and prepare execution plans
PERF_WARMUP_RUNS=1

# Number of measurement runs for timing (default: 3):
#   Multiple runs provide more accurate median timing
PERF_MEASUREMENT_RUNS=3

# Performance difference threshold percentage (default: 50):
#   Queries with performance difference > this value are flagged as warnings
#   Examples:
#     20 = Strict (20%+ difference triggers warning)
#     50 = Balanced (50%+ difference triggers warning)  [RECOMMENDED]
#     75 = Lenient (75%+ difference triggers warning)
PERF_THRESHOLD_PERCENT=50

# Table Performance Testing (NEW - auto-generates queries for all tables):
#   Enable/disable automatic table performance testing
#   When enabled, generates COUNT, SAMPLE, PK LOOKUP, and ORDERED SCAN queries
#   for all tables in the schema (default: true)
ENABLE_TABLE_PERFORMANCE_TESTS=true

# Maximum number of tables to test (default: 100):
#   Limits the number of tables tested to avoid excessive test duration
#   Set to a higher value if you want to test more tables
MAX_TABLES_TO_TEST=100

# Sample row limit for data retrieval tests (default: 100):
#   Number of rows to retrieve in sample queries
#   Smaller values = faster tests, Larger values = more realistic performance
SAMPLE_ROW_LIMIT=100

# Enable specific table test types (default: all true):
#   COUNT tests - SELECT COUNT(*) for each table (tests full table scans)
ENABLE_COUNT_TESTS=true

#   SAMPLE tests - SELECT * LIMIT for each table (tests data retrieval)
ENABLE_SAMPLE_TESTS=true

#   PK LOOKUP tests - SELECT * WHERE pk = value (tests index usage)
ENABLE_PK_LOOKUP_TESTS=true

#   ORDERED SCAN tests - SELECT * ORDER BY pk LIMIT (tests sort performance)
ENABLE_ORDERED_SCAN_TESTS=true

# Optional: Custom query paths (leave empty to use default paths):
#   Default paths: queries/oracle and queries/postgres relative to executable
# ORACLE_QUERIES_PATH=/custom/path/to/oracle/queries
# POSTGRES_QUERIES_PATH=/custom/path/to/postgres/queries

# ============================================================================
# HASH SETTINGS
# ============================================================================

# Hash Algorithm (SHA256 recommended, or MD5):
HASH_ALGORITHM=SHA256

# Save hash values to CSV files:
SAVE_HASHES_TO_CSV=true

# ============================================================================
# COLUMN FILTERING
# ============================================================================

# Columns to Skip in PostgreSQL (comma-separated list):
#   Use this when PostgreSQL has additional columns that don't exist in Oracle
#   Format: column1,column2,column3 (case-insensitive)
#   Example: created_at,updated_at,migration_id
#   Leave empty to compare all columns
POSTGRES_SKIP_COLUMNS=

# Columns to Skip in Oracle (comma-separated list):
#   Use this when Oracle has additional columns that don't exist in PostgreSQL
#   Format: column1,column2,column3 (case-insensitive)
#   Example: old_column1,deprecated_column2
#   Leave empty to compare all columns
ORACLE_SKIP_COLUMNS=

# ============================================================================
# TABLE/OBJECT FILTERING
# ============================================================================

# Table Exclusion Patterns (comma-separated substring matches):
#   Tables containing any of these values will be excluded from validation
#   Example: _bk,_bkup,_tmp
TABLE_EXCLUSION_PATTERNS=

# Ignored Objects (comma-separated key=value pairs):
#   Supported prefixes: table=, view=, materialized_view=, sequence=, trigger=,
#   index=, procedure=, function=, package=, foreignkey= (or fk=)
#   
#   Use foreignkey= or fk= to exclude specific foreign key constraints from schema comparison
#   Foreign key issues are reported as WARNINGS (not critical), so this is useful for:
#     - Known FK differences between environments
#     - FKs that will be added post-migration
#     - Legacy FKs that are intentionally different
#   
#   Examples:
#     table=ignored_table,procedure=ignored_sproc
#     view=obsolete_view,view=debug_metrics,table=temp_data
#     foreignkey=FK_LEGACY_REL,fk=FK_OLD_SYSTEM
#     table=AUDIT_LOG;procedure=SP_OLD;foreignkey=FK_USER_ROLE,FK_DEPT_MGR
IGNORED_OBJECTS=

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================

# Schemas to Process (comma-separated, leave empty to discover all):
SCHEMAS_TO_PROCESS=

# PostgreSQL Multi-Database Search:
#   true  = Search ALL databases on PostgreSQL server for required schemas
#   false = Search only the database specified in POSTGRES_DB (default)
POSTGRES_SEARCH_ALL_DATABASES=false
